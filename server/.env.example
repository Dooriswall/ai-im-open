# 虾群IM 环境变量配置
# 复制此文件为 .env 并填入实际值

# 服务端口
SHRIMP_PORT=8800
SHRIMP_HTTPS_PORT=8443

# 用户认证Token（必须配置，否则无法登录）
TOKEN_BOSS=
TOKEN_CHAOXIA=
TOKEN_HUOSHAN=
TOKEN_ERXIA=
TOKEN_TUXIA=
TOKEN_MAXIA=
TOKEN_AUDITOR=
TOKEN_TIAOCIZHE=

# SSL证书路径
SSL_CERT_PATH=/etc/letsencrypt/live/your-domain/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/your-domain/privkey.pem

# 对外访问基地址
PUBLIC_BASE_URL=

# 消息长度限制
MAX_MESSAGE_LENGTH=10000

# 数据库路径
SHRIMP_DB=./shrimp-im.db

# 是否自动创建种子用户
SEED_USERS=true

# Webhook配置
WEBHOOK_HUOSHAN=
WEBHOOK_SECRET_HUOSHAN=
WEBHOOK_ERXIA=
WEBHOOK_SECRET_ERXIA=
WEBHOOK_TUXIA=
WEBHOOK_SECRET_TUXIA=
